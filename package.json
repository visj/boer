{
  "name": "uvd",
  "version": "0.8.0",
  "description": "Zero allocation type guard and validation against schemas",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js",
      "require": "./dist/catalog.cjs",
      "default": "./dist/catalog.js"
    },
    "./ast": {
      "type": "./dist/ast.d.ts",
      "import": "./dist/ast.js",
      "require": "./dist/ast.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    },
    "./inspect": {
      "types": "./dist/inspect.d.ts",
      "import": "./dist/inspect.js",
      "require": "./dist/inspect.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "make": "node scripts/build.js",
    "inspect": "bun test --expose-gc --inspect-brk --sourcemap=inline ./tests/strict.test.js"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@types/bun": "^1.3.10",
    "ajv": "^8.18.0",
    "mitata": "^1.0.34",
    "valibot": "^1.2.0",
    "zod": "^4.3.6",
    "rolldown": "^1.0.0-rc.9",
    "terser": "^5.46.0"
  },
  "keywords": [
    "JSON",
    "schema",
    "guard"
  ],
  "author": "Vilhelm Sjölund",
  "license": "Apache-2.0",
  "dependencies": {
    "json-schema-typed": "^8.0.2",
    "uri-js": "^4.4.1"
  }
}