{
  "name": "uvd",
  "version": "0.8.0",
  "description": "Zero allocation type guard and validation against schemas",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "make": "node scripts/build.js",
    "inspect": "bun test --expose-gc --inspect-brk --sourcemap=inline ./tests/strict.test.js"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@types/bun": "^1.3.10",
    "ajv": "^8.18.0",
    "mitata": "^1.0.34",
    "valibot": "^1.2.0",
    "zod": "^4.3.6",
    "rolldown": "^1.0.0-rc.9",
    "terser": "^5.46.0"
  },
  "keywords": [
    "JSON",
    "schema",
    "guard"
  ],
  "author": "Vilhelm Sjölund",
  "license": "MIT"
}