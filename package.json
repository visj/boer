{
  "name": "uvd",
  "version": "0.2.0",
  "description": "A javascript type validation runtime",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "default": "./dist/core.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "make": "node scripts/build.js",
    "bench": "node --expose-gc bench/bench.js",
    "inspect": "bun test --expose-gc --inspect-brk --sourcemap=inline ./tests/suite.test.js",
    "coverage": "c8 --reporter=html node --expose-gc bench/bench_huge.js"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@types/bun": "^1.3.10",
    "ajv": "^8.18.0",
    "c8": "^11.0.0",
    "json-schema-typed": "^8.0.2",
    "mitata": "^1.0.34",
    "rolldown": "^1.0.0-rc.9",
    "terser": "^5.46.0",
    "valibot": "^1.2.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "JSON",
    "schema",
    "guard"
  ],
  "author": "Vilhelm Sjölund",
  "license": "Apache-2.0",
  "dependencies": {
    "@mitata/counters": "^0.0.8",
    "uri-js": "^4.4.1"
  }
}