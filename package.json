{
  "name": "luvd",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "make": "node scripts/build.js",
    "bench": "node --expose-gc bench/bench.js",
    "inspect": "bun test --expose-gc --inspect-brk --sourcemap=inline ./tests/suite.test.js",
    "coverage": "c8 --reporter=clover node --expose-gc bench/bench_huge.js"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@types/bun": "^1.3.10",
    "@luvd/core": "workspace:*",
    "@luvd/validate": "workspace:*",
    "@luvd/builder": "workspace:*",
    "@luvd/schema": "workspace:*",
    "@luvd/compiler": "workspace:*",
    "@luvd/conform": "workspace:*",
    "@luvd/diagnose": "workspace:*",
    "@luvd/inspect": "workspace:*",
    "ajv": "^8.18.0",
    "c8": "^11.0.0",
    "json-schema-typed": "^8.0.2",
    "mitata": "^1.0.34",
    "rolldown": "^1.0.0-rc.9",
    "terser": "^5.46.0",
    "valibot": "^1.2.0",
    "zod": "^4.3.6",
    "@mitata/counters": "^0.0.8",
    "ajv-draft-04": "^1.0.0"
  },
  "keywords": [
    "JSON",
    "schema",
    "guard"
  ],
  "author": "Vilhelm Sjölund",
  "license": "Apache-2.0",
  "dependencies": {
    "uri-js": "^4.4.1"
  }
}