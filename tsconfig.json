{
  "compilerOptions": {
    /* Target ES2015 to support Map and Typed Arrays */
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    /* Enable JS checking without generating output files */
    "noEmit": true,
    "strict": true,
    "checkJs": true,
    "skipLibCheck": true,
    "allowJs": true,
    "module": "node16",
    "moduleResolution": "node16"
  },
  "include": [
    "src/*.js",
    "types/*.d.ts",
    "global.d.ts"
  ]
}