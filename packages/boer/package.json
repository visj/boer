{
  "name": "boer",
  "version": "0.2.1",
  "description": "A javascript type validation runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "make": "node scripts/build.js"
  },
  "dependencies": {
      "@boer/core": "0.2.1",
      "@boer/builder": "0.2.1",
      "@boer/validate": "0.2.1",
      "@boer/diagnose": "0.2.1"
  },
  "devDependencies": {
    "@boer/core": "workspace:*",
    "@boer/validate": "workspace:*",
    "@boer/builder": "workspace:*",
    "@boer/diagnose": "workspace:*"
  },
  "keywords": [
    "json-schema",
    "json",
    "schema",
    "type",
    "validation",
    "validator",
    "typescript",
    "infer"
  ],
  "author": "Vilhelm Sjölund",
  "license": "Apache-2.0"
}
