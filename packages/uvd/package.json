{
  "name": "uvd",
  "version": "0.2.0",
  "description": "A javascript type validation runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "make": "node scripts/build.js"
  },
  "dependencies": {
    "@uvd/core": "workspace:*",
    "@uvd/validate": "workspace:*",
    "@uvd/builder": "workspace:*",
    "@uvd/diagnose": "workspace:*",
    "@uvd/conform": "workspace:*"
  },
  "keywords": [
    "JSON",
    "schema",
    "guard"
  ],
  "author": "Vilhelm Sjölund",
  "license": "Apache-2.0"
}
